# Port the backend listens on
PORT=3000

# Fronius inverter local IP address
FRONIUS_HOST=http://192.168.1.30

# Poll interval in milliseconds (default: 10000)
# POLL_INTERVAL_MS=10000

# SolarWeb cloud API — PV system ID (from the URL when viewing your system)
# SOLARWEB_PV_SYSTEM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Auth option 1: API access keys (SolarWeb → System settings → Access Keys)
# SOLARWEB_ACCESS_KEY_ID=
# SOLARWEB_ACCESS_KEY_VALUE=

# Auth option 2: SolarWeb account credentials (email + password)
# SOLARWEB_USERNAME=your@email.com
# SOLARWEB_PASSWORD=your-solarweb-password

# History sync: fetch all daily stats from this date onward.
# If not set, the commissioning date is fetched from the SolarWeb API automatically.
# Trigger with: curl -X POST http://localhost:3000/api/solarweb/sync-history
# SOLARWEB_HISTORY_START=2023-01-01

# Modbus TCP — enable in Fronius web UI under Settings → Modbus → "Modbus TCP"
# Read-only access works with MODBUS_ENABLED=true (no extra inverter config needed).
# Write access (battery control) requires additionally enabling
# "Control via Modbus" in the inverter settings.
# MODBUS_ENABLED=false
# MODBUS_HOST=192.168.1.30   # plain IP, no http:// prefix (auto-extracted from FRONIUS_HOST if omitted)
# MODBUS_PORT=502
# GEN24 SunSpec registers (float mode, unit ID 1 for inverter, 200 for smart meter)
# These defaults match the Fronius Symo GEN24 register map — adjust if your firmware differs.
# MODBUS_STORAGE_CTRL_REGISTER=40348
# MODBUS_CHARGE_RATE_REGISTER=40354

# Cloudflare Tunnel token (cloudflared deployment only)
# TUNNEL_TOKEN=
