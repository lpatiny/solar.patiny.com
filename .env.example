# Deployment mode: uncomment exactly ONE line to choose how the service is
# exposed. With none uncommented, docker compose uses compose.yaml by default.
# compose.yaml and compose.cloudflared.yaml run host-networked so the Marstek
# battery poller's UDP-broadcast discovery / self-heal works; compose.traefik.yaml
# stays on a bridge network (broadcast discovery unavailable — see that file).
# COMPOSE_FILE=compose.yaml             # host-networked, binds PORT on the host
# COMPOSE_FILE=compose.traefik.yaml     # behind a Traefik reverse proxy (bridge)
# COMPOSE_FILE=compose.cloudflared.yaml # behind a Cloudflare Tunnel (host-networked)

# Container timezone — affects log timestamps and date display in the frontend.
# Find your value with: timedatectl list-timezones | grep Europe
TZ=Europe/Zurich

# Port the backend listens on
PORT=3000

# Authentication for the battery-control routes (changing charge power, adding /
# editing / deleting devices). Read-only monitoring stays public.
AUTH_USERNAME=admin
AUTH_PASSWORD=lpclpc
# Session signing secret — must be at least 32 characters. Generate with:
# openssl rand -hex 32
SESSION_SECRET=

# Fronius inverter local IP address
FRONIUS_HOST=http://192.168.1.30

# Poll interval in milliseconds (default: 10000)
# POLL_INTERVAL_MS=10000

# SolarWeb cloud API — PV system ID (from the URL when viewing your system)
# SOLARWEB_PV_SYSTEM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Auth option 1: API access keys (SolarWeb → System settings → Access Keys)
# SOLARWEB_ACCESS_KEY_ID=
# SOLARWEB_ACCESS_KEY_VALUE=

# Auth option 2: SolarWeb account credentials (email + password)
# SOLARWEB_USERNAME=your@email.com
# SOLARWEB_PASSWORD=your-solarweb-password

# History sync: fetch all daily stats from this date onward.
# If not set, the commissioning date is fetched from the SolarWeb API automatically.
# Trigger with: curl -X POST http://localhost:3000/api/solarweb/sync-history
# SOLARWEB_HISTORY_START=2023-01-01

# Solar panel model correction factors — stored in the DB and editable via the UI.
# PANEL_PERFORMANCE_RATIO accounts for inverter efficiency + wiring losses (default: 0.85).
# PANEL_TEMP_COEFF_PCT_PER_C is the module's temperature coefficient in %/°C (default: 0.40).
# These are only used as startup defaults if not already saved in the database.
# PANEL_PERFORMANCE_RATIO=0.85
# PANEL_TEMP_COEFF_PCT_PER_C=0.40

# Modbus TCP — enable in Fronius web UI under Settings → Modbus → "Modbus TCP"
# Read-only access works with MODBUS_ENABLED=true (no extra inverter config needed).
# Write access (battery control) requires additionally enabling
# "Control via Modbus" in the inverter settings.
# MODBUS_ENABLED=false
# MODBUS_HOST=192.168.1.30   # plain IP, no http:// prefix (auto-extracted from FRONIUS_HOST if omitted)
# MODBUS_PORT=502
# GEN24 SunSpec registers (float mode, unit ID 1 for inverter, 200 for smart meter)
# These defaults match the Fronius Symo GEN24 register map — adjust if your firmware differs.
# MODBUS_STORAGE_CTRL_REGISTER=40348
# MODBUS_CHARGE_RATE_REGISTER=40354

# Cloudflare Tunnel token (cloudflared deployment only)
# TUNNEL_TOKEN=
